# 复制此文件为 .env 并根据需要修改

# 服务器配置
HOST=0.0.0.0          # 监听地址：0.0.0.0=所有网卡（支持局域网访问），127.0.0.1=仅本地
PORT=8010             # API 服务端口

# 调度器配置
# 最大并发任务数（1-32）
MAX_CONCURRENT=10

# 数据库配置
DB_PATH=backend/task_manager.db

# CORS 配置 (逗号分隔的允许源)
CORS_ORIGINS_STR=http://localhost:3010,http://127.0.0.1:3010

# 任务超时配置（秒）
# 任务执行的最大时长，超过此时间将被强制终止
# 范围：60-86400 秒（1 分钟 -24 小时）
TASK_TIMEOUT=3600

# 后处理超时配置（秒）
# 后处理（merge/cleanup）的最大执行时间
# 范围：60-3600 秒（1 分钟 -1 小时）
POST_PROCESS_TIMEOUT=600

# 认证配置
# 登录密码（未设置或为空则跳过认证，不要求登录）
PASSWORD=

# Session 有效期（秒）
# 范围：3600-604800 秒（1 小时 -7 天）
SESSION_MAX_AGE=86400
