# 复制此文件为 .env 并根据需要修改
# 注意：这些变量仅在本地开发时使用，Docker 部署时在 docker-compose.yml 中配置

# API 配置（本地开发时使用）
API_DOMAIN=http://localhost:8010   # 局域网访问时改为 http://<本机 IP>:8010
WS_DOMAIN=ws://localhost:8010      # 局域网访问时改为 ws://<本机 IP>:8010

# 前端服务器配置
NEXT_HOST=0.0.0.0    # 监听地址：0.0.0.0=所有网卡（支持局域网访问），127.0.0.1=仅本地
NEXT_PORT=3010       # 前端服务端口

# Docker 部署说明
# 使用 Docker 部署时，在 docker-compose.yml 中配置环境变量：
# environment:
#   - API_DOMAIN=http://backend:8010
#   - WS_DOMAIN=ws://backend:8010
